# Copy to .env for local (non-docker) runs. docker-compose sets these itself.
MERIDIAN_MLFLOW_TRACKING_URI=http://localhost:5500
MERIDIAN_DATA_DIR=data
MERIDIAN_MODEL_NAME=taxi-trip-duration
MERIDIAN_MODEL_ALIAS=production

# Drift detection
MERIDIAN_DRIFT_DATASET_THRESHOLD=0.5
MERIDIAN_DRIFT_WINDOW=500
MERIDIAN_DRIFT_CHECK_INTERVAL_S=30
MERIDIAN_RETRAIN_ON_DRIFT=true

# NVIDIA NIM (build.nvidia.com) — powers the dashboard's AI root-cause analysis
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# Used by the dashboard's Live mode predictor
MERIDIAN_SERVING_URL=http://localhost:8000
