{
  "title": "Meridian — Serving & Drift",
  "uid": "meridian-main",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Data drift share (live vs reference)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "max": 1, "min": 0
        }
      },
      "targets": [
        { "expr": "meridian_data_drift_share", "legendFormat": "drift share" }
      ]
    },
    {
      "type": "stat",
      "title": "Dataset drift state",
      "gridPos": { "h": 9, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "STABLE", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "DRIFTED", "color": "red" } } }
          ]
        }
      },
      "targets": [{ "expr": "meridian_dataset_drift" }]
    },
    {
      "type": "stat",
      "title": "Retrains triggered",
      "gridPos": { "h": 9, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "meridian_retrains_triggered_total" }]
    },
    {
      "type": "timeseries",
      "title": "Predictions / sec",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "targets": [
        { "expr": "rate(meridian_predictions_total[1m])", "legendFormat": "req/s" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Inference latency (p50/p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(meridian_prediction_latency_seconds_bucket[1m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(meridian_prediction_latency_seconds_bucket[1m]))", "legendFormat": "p95" }
      ]
    },
    {
      "type": "bargauge",
      "title": "Per-feature drift",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "fieldConfig": { "defaults": { "max": 1, "min": 0 } },
      "targets": [
        { "expr": "meridian_feature_drift", "legendFormat": "{{feature}}" }
      ]
    }
  ]
}
